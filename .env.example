# Backend API Configuration
# Dify API URL - shared by both chat and goal generation
DIFY_API_URL=https://api.dify.ai/v1

# Dify API Key for chat feature
DIFY_API_KEY=your_dify_chat_api_key_here

# Dify API Key for goal generation workflow
DIFY_GOAL_API_KEY=your_dify_goal_api_key_here

# Frontend API URL (for connecting to backend)
VITE_API_URL=http://localhost:8001

# Allowed origins for CORS (comma-separated, for cross-site API access)
# ALLOWED_ORIGINS=https://example.com,https://another-site.com