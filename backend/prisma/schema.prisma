// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Article {
  id            String   @id @default(uuid())
  title         String
  summary       String
  content       String   @db.Text
  publishDate   DateTime
  tags          String[]
  readTime      Int
  coverImage    String?
  link          String?
  type          String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Draft {
  id            String   @id @default(uuid())
  title         String
  summary       String
  content       String   @db.Text
  publishDate   DateTime
  tags          String[]
  readTime      Int
  coverImage    String?
  link          String?
  type          String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Craft {
  id            String   @id @default(uuid())
  name          String
  description   String   @db.Text
  category      String   // component, effect, control, demo, experiment
  technologies  String[]
  featured      Boolean  @default(false)
  weight        Int      @default(1)
  coverImage    String?
  htmlCode      String?  @db.Text
  configSchema  Json?    // 配置项 Schema [{key, label, type, defaultValue, min?, max?, step?, options?}]
  useCase       String?  @db.Text
  githubUrl     String?
  content       String?  @db.Text
  relations     Json?    // 存储关系数组 [{targetId, type}]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Idea {
  id            String   @id @default(uuid())
  name          String
  description   String   @db.Text
  category      String   // component, effect, control, demo, experiment
  weight        Int      @default(1)
  image         String?
  video         String?
  linkUrl       String?
  useCase       String?  @db.Text
  group         String?  // 组别ID
  relations     Json?    // 存储关系数组 [{targetId, type}]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Workflow {
  id                String   @id @default(uuid())
  name              String
  icon              String
  description       String   @db.Text
  steps             Json     // [{agentId, skillId, action, inputFrom?}]
  startTime         String?
  endTime           String?
  scheduled         Boolean  @default(false)
  scheduledEnabled  Boolean  @default(false)
  cron              String?
  persistent        Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Assistant {
  id                String   @id @default(uuid())
  assistantId       String   @unique  // 业务 ID (如 'manager', 'writer')
  name              String
  role              String
  description       String   @db.Text
  accent            String
  systemPrompt      String   @db.Text
  skills            Json     // Skill[]
  item              String
  catColors         Json     // CatColors 对象
  messages          String[]
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model WorkflowRun {
  id                String   @id @default(uuid())
  workflowId        String?  // 关联的 Workflow ID（可选，一次性任务可能无关联）
  workflowName      String
  agentId           String
  skillId           String
  stepIndex         Int      @default(0)
  summary           String   @db.Text
  result            String   @db.Text
  status            String   // success, warning, error
  executedAt        DateTime @default(now())
  duration          Int?     // 执行耗时（毫秒）
  createdAt         DateTime @default(now())
}

model Goal {
  id                    String   @id @default(uuid())
  title                 String
  description           String   @db.Text
  category              String   // technical, personal, creative, business, health, social
  priority              String   // high, medium, low
  status                String   // planning, active, paused, completed, archived
  progress              Int      @default(0)
  duration              Int      // 周期天数
  startDate             String   // YYYY-MM-DD
  endDate               String   // YYYY-MM-DD
  actualStartDate       String?  // 实际开始日期
  pausedAt              String?  // 暂停时间
  totalPausedDuration   BigInt   @default(0) // 总暂停时长（毫秒）
  targetSkills          String[]
  milestones            Json?    // 里程碑数组
  successCriteria       String[] // 成功标准
  generatedData         Json?    // 存储 Dify 生成的输入输出数据
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

